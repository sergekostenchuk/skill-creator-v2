{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/skill-creator-v2/evidence-contract-schema.json",
  "title": "Skill Creator V2 Evidence Contract",
  "type": "object",
  "additionalProperties": false,
  "required": ["evidence"],
  "properties": {
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "evidence_id",
          "type",
          "claim_supported",
          "why_needed",
          "collection_method",
          "artifact_path",
          "validator",
          "required_for_done",
          "sanitation_rule",
          "status"
        ],
        "properties": {
          "evidence_id": {
            "type": "string",
            "pattern": "^E-[0-9]{3,}$"
          },
          "type": {
            "type": "string",
            "enum": [
              "command_output",
              "config_diff",
              "test_result",
              "screenshot",
              "dom_metadata",
              "network_log",
              "source_citation",
              "legal_citation",
              "source_hash",
              "package_hash",
              "benchmark_metric",
              "human_approval",
              "before_after_comparison",
              "rollback_proof",
              "generated_artifact",
              "visual_review",
              "trace_log",
              "decision_packet"
            ]
          },
          "claim_supported": {
            "type": "string",
            "minLength": 1
          },
          "why_needed": {
            "type": "string",
            "minLength": 1
          },
          "collection_method": {
            "type": "string",
            "minLength": 1
          },
          "artifact_path": {
            "type": "string",
            "minLength": 1
          },
          "validator": {
            "type": "string",
            "minLength": 1
          },
          "required_for_done": {
            "type": "boolean"
          },
          "sanitation_rule": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": ["planned", "collected", "validated", "blocked", "waived_with_risk"]
          }
        }
      }
    }
  }
}
